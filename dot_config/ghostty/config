font-family = "FiraMono Nerd Font Mono Regular"

theme = Flexoki Dark
background-opacity = .93
background-blur = false
split-divider-color = #454336
# TODO - Figure out unfocused-split-opacity, unfocused-split-fill, cursor coloring

window-decoration = none

window-step-resize = true
confirm-close-surface = false

macos-titlebar-style = tabs
macos-option-as-alt = true
macos-icon = custom
macos-custom-icon = ~/.config/ghostty/ghostty-cafe-espresso.icns

auto-update = download

keybind = global:shift+opt+cmd+ctrl+`=toggle_quick_terminal
quick-terminal-animation-duration = 0

# tmux command+a to enter super mode
keybind = cmd+a=text:\x01

# Window creation
keybind = cmd+t=text:\x01c

# Close Pane
keybind = cmd+w=text:\x01\x78

# Pane splitting
keybind = cmd+d=text:\x01%
keybind = cmd+shift+d=text:\x01"

# Pane Cycling
keybind = cmd+[=text:\x01O
keybind = cmd+]=text:\x01P

# Window Cycling
keybind = ctrl+tab=text:\x01\x6e
keybind = ctrl+shift+tab=text:\x01\x70

# Window management
keybind = cmd+digit_1=text:\x01\x31
keybind = cmd+digit_2=text:\x01\x32
keybind = cmd+digit_3=text:\x01\x33
keybind = cmd+digit_4=text:\x01\x34
keybind = cmd+digit_5=text:\x01\x35
keybind = cmd+digit_6=text:\x01\x36
keybind = cmd+digit_7=text:\x01\x37
keybind = cmd+digit_8=text:\x01\x38
keybind = cmd+digit_9=text:\x01\x39

# Zoom/fullscreen pane
keybind = cmd+z=text:\x02z

# shift + enter newline
keybind = shift+enter=text:\n

# https://github.com/KroneCorylus/ghostty-shader-playground
# From https://github.com/sahaj-b/ghostty-cursor-shaders
custom-shader = shaders/cursor_sweep.glsl

